#!/usr/bin/env python3
"""
tmp-cli: Universal command-line file uploader/downloader for temporary file hosts.
Supports: catbox, litterbox, temp.sh, gofile, pixeldrain, 0x0.st
"""

import argparse
import json
import os
import re
import sys
import time
from abc import ABC, abstractmethod
from dataclasses import dataclass, field
from pathlib import Path
from typing import Dict, List, Optional, Tuple
from urllib.parse import urlparse
import subprocess

SERVICES = ["catbox", "litterbox", "temp.sh", "gofile", "pixeldrain", "0x0"]

@dataclass
class UploadResult:
    url: str
    delete_url: Optional[str] = None
    expires_in: str = ""
    service: str = ""
    file_id: str = ""
    token: str = ""

@dataclass
class PerfRecord:
    upload_times: List[float] = field(default_factory=list)
    success_count: int = 0
    failure_count: int = 0
    avg_speed_mbps: float = 0.0

class BaseService(ABC):
    name: str = ""
    max_size_mb: int = 0
    default_expiry: str = ""
    supports_anon: bool = True
    needs_key: bool = False

    @abstractmethod
    def upload(self, file_path: str, **kwargs) -> UploadResult:
        pass

    @abstractmethod
    def download(self, url: str, output_path: str) -> bool:
        pass

    def _curl(self, args: List[str], capture_output=True, timeout=120) -> Tuple[int, str, str]:
        cmd = ["curl", "-s", "-L", "-A", "tmp-cli/1.0"] + args
        try:
            result = subprocess.run(cmd, capture_output=capture_output, text=True, timeout=timeout)
            return result.returncode, result.stdout, result.stderr
        except subprocess.TimeoutExpired:
            return -1, "", "timeout"
        except Exception as e:
            return -1, "", str(e)

class CatboxService(BaseService):
    name = "catbox"
    max_size_mb = 200
    default_expiry = "permanent"

    def upload(self, file_path: str, **kwargs) -> UploadResult:
        code, out, err = self._curl([
            "-F", "reqtype=fileupload",
            "-F", f"fileToUpload=@{file_path}",
            "https://catbox.moe/user/api.php"
        ])
        if code != 0 or not out.startswith("http"):
            raise RuntimeError(f"Catbox upload failed: {err or out}")
        return UploadResult(url=out.strip(), service="catbox", expires_in="permanent")

    def download(self, url: str, output_path: str) -> bool:
        code, _, _ = self._curl(["-o", output_path, url])
        return code == 0 and os.path.exists(output_path) and os.path.getsize(output_path) > 0

class LitterboxService(BaseService):
    name = "litterbox"
    max_size_mb = 1024
    default_expiry = "72h"

    def upload(self, file_path: str, **kwargs) -> UploadResult:
        time_param = kwargs.get("time_param", "72h")
        code, out, err = self._curl([
            "-F", "reqtype=fileupload",
            "-F", f"time={time_param}",
            "-F", f"fileToUpload=@{file_path}",
            "https://litterbox.catbox.moe/resources/internals/api.php"
        ])
        if code != 0 or not out.startswith("http"):
            raise RuntimeError(f"Litter upload failed: {err or out}")
        return UploadResult(url=out.strip(), service="litterbox", expires_in=time_param)

    def download(self, url: str, output_path: str) -> bool:
        code, _, _ = self._curl(["-o", output_path, url])
        return code == 0

class TempShService(BaseService):
    name = "temp.sh"
    max_size_mb = 4096
    default_expiry = "3d"

    def upload(self, file_path: str, **kwargs) -> UploadResult:
        code, out, err = self._curl([
            "-F", f"file=@{file_path}",
            "https://temp.sh/upload"
        ])
        if code != 0 or not out.startswith("https://"):
            raise RuntimeError(f"temp.sh upload failed: {err or out}")
        return UploadResult(url=out.strip(), service="temp.sh", expires_in="3 days")

    def download(self, url: str, output_path: str) -> bool:
        # temp.sh requires POST to trigger download
        code, _, err = self._curl([
            "-X", "POST", "-o", output_path, url
        ])
        ok = code == 0 and os.path.exists(output_path) and os.path.getsize(output_path) > 0
        if not ok:
            # Try redirect chain
            code2, _, _ = self._curl(["-o", output_path, "-L", url])
            ok = code2 == 0 and os.path.exists(output_path) and os.path.getsize(output_path) > 0
        return ok

class GofileService(BaseService):
    name = "gofile"
    max_size_mb = 0
    default_expiry = "variable"
    API_SALT = "g4f8fd9f12h14g"
    UA = "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"

    def _create_account(self) -> str:
        """Create a disposable guest account."""
        import json as _json
        import urllib.request
        req = urllib.request.Request(
            "https://api.gofile.io/accounts",
            data=b"",
            headers={
                "Accept": "*/*",
                "User-Agent": self.UA,
                "Origin": "https://gofile.io",
                "Referer": "https://gofile.io/",
            },
            method="POST",
        )
        try:
            with urllib.request.urlopen(req, timeout=15) as resp:
                data = _json.loads(resp.read().decode())
                if data.get("status") == "ok":
                    return data["data"]["token"]
        except Exception:
            pass
        return ""

    def _generate_website_token(self, account_token: str) -> str:
        import hashlib, time
        timeslot = int(time.time()) // 14400
        raw = f"{self.UA}::en-US::{account_token}::{timeslot}::{self.API_SALT}"
        return hashlib.sha256(raw.encode()).hexdigest()

    def upload(self, file_path: str, **kwargs) -> UploadResult:
        # Get server
        _, serv_json, _ = self._curl([
            "-H", "Accept: application/json",
            "https://api.gofile.io/servers"
        ])
        server = "store-eu-par-2"
        try:
            data = json.loads(serv_json)
            server = data["data"]["servers"][0]["name"]
        except:
            pass
        code, out, err = self._curl([
            "-F", f"file=@{file_path}",
            f"https://{server}.gofile.io/contents/uploadfile"
        ])
        if code != 0:
            raise RuntimeError(f"Gofile upload failed: {err}")
        try:
            resp = json.loads(out)
            if resp.get("status") != "ok":
                raise RuntimeError(f"Gofile API error: {resp}")
            d = resp["data"]
            return UploadResult(
                url=d["downloadPage"],
                service="gofile",
                expires_in="varies",
                file_id=d["id"],
                token=d.get("guestToken", "")
            )
        except json.JSONDecodeError:
            raise RuntimeError(f"Gofile bad JSON: {out[:200]}")

    def download(self, url: str, output_path: str) -> bool:
        parsed = urlparse(url)
        code = parsed.path.split("/")[-1]

        # Create account
        account_token = self._create_account()
        if not account_token:
            print("[warn] gofile: failed to create account, trying fallback", file=sys.stderr)
            return self._download_from_page(url, output_path, "")

        # Generate website token
        wt = self._generate_website_token(account_token)

        # Call API
        api_url = f"https://api.gofile.io/contents/{code}?cache=true"
        jargs = [
            "-H", f"Authorization: Bearer {account_token}",
            "-H", f"X-Website-Token: {wt}",
            "-H", "X-BL: en-US",
            "-H", f"User-Agent: {self.UA}",
            "-H", "Origin: https://gofile.io",
            "-H", "Referer: https://gofile.io/",
            api_url,
        ]
        _, api_json, _ = self._curl(jargs)
        direct_link = ""
        try:
            api_resp = json.loads(api_json)
            if api_resp.get("status") == "ok":
                children = api_resp["data"].get("children", {})
                if children:
                    fi = list(children.values())[0]
                    direct_link = fi.get("link", "")
        except Exception as e:
            print(f"[warn] gofile API parse error: {e}", file=sys.stderr)

        if direct_link:
            # gofile requires auth headers + cookies on download too
            dl_args = [
                "-o", output_path,
                "-H", f"Authorization: Bearer {account_token}",
                "-H", f"X-Website-Token: {wt}",
                "-H", f"User-Agent: {self.UA}",
                "-H", "Origin: https://gofile.io",
                "-H", "Referer: https://gofile.io/",
                "-H", "Accept: */*",
                "-b", f"accountToken={account_token}",
                "-L", direct_link,
            ]
            d_code, _, _ = self._curl(dl_args)
            ok = d_code == 0 and os.path.exists(output_path) and os.path.getsize(output_path) > 0
            if ok:
                return True

        return self._download_from_page(url, output_path, "")

    def _download_from_page(self, url: str, output_path: str, page_html: str) -> bool:
        # Try common URL patterns
        parsed = urlparse(url)
        code = parsed.path.split("/")[-1]
        patterns = [
            f"https://store1.gofile.io/download/{code}",
            f"https://store-eu-par-2.gofile.io/download/{code}",
        ]
        for pat in patterns:
            d_code, _, _ = self._curl(["-o", output_path, pat])
            if d_code == 0 and os.path.exists(output_path) and os.path.getsize(output_path) > 0:
                return True
        return False

class NullPointerService(BaseService):
    name = "0x0"
    max_size_mb = 512
    default_expiry = "30d-1y"
    DISABLED_MSG = "uploads disabled"

    def upload(self, file_path: str, **kwargs) -> UploadResult:
        args = ["-F", f"file=@{file_path}"]
        if kwargs.get("secret"):
            args += ["-F", "secret="]
        if kwargs.get("expires"):
            args += ["-F", f"expires={kwargs['expires']}"]
        args += ["https://0x0.st"]

        code, out, err = self._curl(args)
        if self.DISABLED_MSG in out.lower() or "botnet" in out.lower():
            raise RuntimeError("0x0.st: uploads temporarily disabled")
        if code != 0 or not out.startswith("http"):
            raise RuntimeError(f"0x0.st upload failed: {err or out}")
        url = out.strip()
        expires = f"~{kwargs.get('expires')}h" if kwargs.get("expires") else "auto"
        return UploadResult(url=url, service="0x0", expires_in=expires)

    def download(self, url: str, output_path: str) -> bool:
        code, _, _ = self._curl(["-o", output_path, url])
        return code == 0

class PixeldrainService(BaseService):
    name = "pixeldrain"
    max_size_mb = 10240
    default_expiry = "60dl"
    needs_key = True

    def __init__(self, api_key: str = ""):
        self.api_key = api_key

    def upload(self, file_path: str, **kwargs) -> UploadResult:
        if not self.api_key:
            raise RuntimeError("pixeldrain upload requires API key. Get one at https://pixeldrain.com/user/api_keys")
        code, out, err = self._curl([
            "-u", f"{self.api_key}:",
            "-F", f"file=@{file_path}",
            "https://pixeldrain.com/api/file"
        ])
        if code != 0:
            raise RuntimeError(f"pixeldrain upload failed: {err}")
        try:
            resp = json.loads(out)
            if not resp.get("success", True):
                raise RuntimeError(f"pixeldrain API: {resp}")
            fid = resp["id"]
            return UploadResult(
                url=f"https://pixeldrain.com/u/{fid}",
                service="pixeldrain",
                expires_in="60 days",
                file_id=fid
            )
        except json.JSONDecodeError:
            raise RuntimeError(f"pixeldrain bad JSON: {out[:200]}")

    def download(self, url: str, output_path: str) -> bool:
        m = re.search(r'pixeldrain\.com/u?/([A-Za-z0-9]+)', url)
        if not m:
            return False
        fid = m.group(1)
        dl_url = f"https://pixeldrain.com/api/file/{fid}"
        if self.api_key:
            dl_url = f"https://pixeldrain.com/api/file/{fid}?download"
        code, _, _ = self._curl(["-o", output_path, dl_url])
        return code == 0 and os.path.exists(output_path) and os.path.getsize(output_path) > 0

class TmpCli:
    def __init__(self):
        self.perf: Dict[str, PerfRecord] = {}
        self.config_dir = Path.home() / ".config" / "tmp-cli"
        self.config_dir.mkdir(parents=True, exist_ok=True)
        self.perf_file = self.config_dir / "perf.json"
        self.load_perf()

        self.services: Dict[str, BaseService] = {
            "catbox": CatboxService(),
            "litterbox": LitterboxService(),
            "temp.sh": TempShService(),
            "gofile": GofileService(),
            "0x0": NullPointerService(),
            "pixeldrain": PixeldrainService(os.environ.get("PIXELDRAIN_API_KEY", "")),
        }

    def load_perf(self):
        if self.perf_file.exists():
            try:
                data = json.loads(self.perf_file.read_text())
                for svc, rec in data.items():
                    self.perf[svc] = PerfRecord(
                        upload_times=rec.get("upload_times", []),
                        success_count=rec.get("success_count", 0),
                        failure_count=rec.get("failure_count", 0),
                        avg_speed_mbps=rec.get("avg_speed_mbps", 0.0)
                    )
            except:
                pass

    def save_perf(self):
        data = {}
        for svc, rec in self.perf.items():
            data[svc] = {
                "upload_times": rec.upload_times[-10:],
                "success_count": rec.success_count,
                "failure_count": rec.failure_count,
                "avg_speed_mbps": rec.avg_speed_mbps,
            }
        self.perf_file.write_text(json.dumps(data, indent=2))

    def record_upload(self, svc: str, elapsed: float, success: bool, size_mb: float):
        if svc not in self.perf:
            self.perf[svc] = PerfRecord()
        rec = self.perf[svc]
        rec.upload_times.append(elapsed)
        rec.upload_times = rec.upload_times[-10:]
        if success:
            rec.success_count += 1
            if elapsed > 0:
                speed = size_mb / elapsed
                rec.avg_speed_mbps = 0.7 * rec.avg_speed_mbps + 0.3 * speed if rec.avg_speed_mbps else speed
        else:
            rec.failure_count += 1
        self.save_perf()

    def smart_select(self, file_path: str, preferred: List[str] = None) -> str:
        size_mb = os.path.getsize(file_path) / (1024 * 1024)
        candidates = preferred or list(self.services.keys())

        eligible = []
        for svc in candidates:
            s = self.services[svc]
            if s.max_size_mb > 0 and size_mb > s.max_size_mb:
                continue
            if s.needs_key and not os.environ.get("PIXELDRAIN_API_KEY"):
                continue
            eligible.append(svc)

        if not eligible:
            eligible = ["gofile"]  # gofile unlimited fallback
            if self.services["gofile"].max_size_mb == 0 or size_mb <= self.services["gofile"].max_size_mb:
                pass
            else:
                raise RuntimeError(f"No service can handle {size_mb:.1f}MB file")

        def score(svc: str) -> float:
            rec = self.perf.get(svc, PerfRecord())
            speed = rec.avg_speed_mbps if rec.avg_speed_mbps else 1.0
            total = rec.success_count + rec.failure_count
            rate = rec.success_count / total if total > 0 else 0.5
            penalty = rec.failure_count * 0.3
            return speed * 3 + rate * 2 - penalty

        eligible.sort(key=score, reverse=True)
        return eligible[0]

    def upload(self, file_path: str, service: str = None, **kwargs) -> UploadResult:
        path = Path(file_path)
        if not path.exists():
            raise FileNotFoundError(file_path)

        if service:
            if service not in self.services:
                raise ValueError(f"Unknown service: {service}")
            svc_name = service
        else:
            svc_name = self.smart_select(file_path)

        svc = self.services[svc_name]
        print(f"[*] Uploading to {svc_name}...", file=sys.stderr)
        size_mb = os.path.getsize(file_path) / (1024 * 1024)

        t0 = time.time()
        success = False
        try:
            result = svc.upload(file_path, **kwargs)
            success = True
            elapsed = time.time() - t0
            self.record_upload(svc_name, elapsed, True, size_mb)
            print(f"[+] {result.url}", file=sys.stderr)
            return result
        except Exception as e:
            elapsed = time.time() - t0
            self.record_upload(svc_name, elapsed, False, size_mb)
            print(f"[!] {svc_name} failed: {e}", file=sys.stderr)
            fallback = [s for s in self.services if s != svc_name and not self.services[s].needs_key]
            for fb in fallback[:2]:
                print(f"[*] Trying fallback: {fb}...", file=sys.stderr)
                try:
                    return self.upload(file_path, service=fb, **kwargs)
                except Exception as e2:
                    print(f"[!] {fb} also failed: {e2}", file=sys.stderr)
            raise RuntimeError(f"All services failed. Last error: {e}")

    def download(self, url: str, output_path: str = None) -> bool:
        parsed = urlparse(url)
        domain = parsed.netloc.lower()

        svc_name = None
        for name in self.services:
            key = name.replace(".", "")
            if key in domain or name in domain:
                svc_name = name
                break
        if not svc_name:
            # Try to download anyway with plain curl (might be direct link)
            out = output_path or Path(os.getcwd()) / "downloaded_file"
            code, _, _ = self.services["catbox"]._curl(["-o", str(out), url])
            return code == 0

        svc = self.services[svc_name]
        if not output_path:
            out = Path(os.getcwd()) / Path(url).name
            if not out.name or out.name in ["", "/"]:
                out = Path(os.getcwd()) / "downloaded_file"
            output_path = str(out)

        print(f"[*] Downloading from {svc_name}...", file=sys.stderr)
        return svc.download(url, output_path)


def main():
    parser = argparse.ArgumentParser(prog="tmp", description="Universal temp file uploader/downloader")
    subparsers = parser.add_subparsers(dest="command", help="Commands: up, dl, list")

    up = subparsers.add_parser("up", help="Upload file")
    up.add_argument("file", help="File to upload")
    up.add_argument("-s", "--service", choices=SERVICES, help="Target service")
    up.add_argument("-t", "--time", default="72h", help="Expire time (litterbox: 1h/12h/24h/72h)")
    up.add_argument("-n", "--name", help="Custom filename on server (not all services)")
    up.add_argument("--secret", action="store_true", help="Use secret URL (0x0.st)")
    up.add_argument("--pixeldrain-key", help="Pixeldrain API key")

    dl = subparsers.add_parser("dl", help="Download file")
    dl.add_argument("url", help="URL to download")
    dl.add_argument("-o", "--output", help="Output path")

    ls_cmd = subparsers.add_parser("list", help="List services and status")
    ls_cmd.add_argument("--perf", action="store_true", help="Show performance stats")

    args = parser.parse_args()
    cli = TmpCli()

    if args.command in ("up",):
        kwargs = {}
        if args.service == "litterbox":
            kwargs["time_param"] = args.time
        if args.service == "0x0" and args.secret:
            kwargs["secret"] = True
        if args.pixeldrain_key:
            os.environ["PIXELDRAIN_API_KEY"] = args.pixeldrain_key
        result = cli.upload(args.file, service=args.service, **kwargs)
        print(result.url)

    elif args.command in ("dl",):
        ok = cli.download(args.url, args.output)
        sys.exit(0 if ok else 1)

    elif args.command in ("list",):
        print("Services:")
        print(f"  {'Name':<12} {'Anon':<5} {'MaxSize':<10} {'Expiry':<12}")
        print(f"  {'-'*12} {'-'*4} {'-'*9} {'-'*11}")
        for name, svc in cli.services.items():
            anon = "yes" if svc.supports_anon else "no"
            size = f"{svc.max_size_mb}MB" if svc.max_size_mb > 0 else "unltd"
            print(f"  {name:<12} {anon:<5} {size:<10} {svc.default_expiry:<12}")
        if args.perf:
            print("\nPerformance:")
            for name, rec in cli.perf.items():
                print(f"  {name}: avg={rec.avg_speed_mbps:.2f}MB/s  succ={rec.success_count}  fail={rec.failure_count}")
    else:
        parser.print_help()

if __name__ == "__main__":
    main()
