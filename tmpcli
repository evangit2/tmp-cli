class TmpCli:
    def __init__(self):
        self.perf: Dict[str, PerfRecord] = {}
        self.config_dir = Path.home() / ".config" / "tmp-cli"
        self.config_dir.mkdir(parents=True, exist_ok=True)
        self.perf_file = self.config_dir / "perf.json"
        self.load_perf()

        self.services: Dict[str, BaseService] = {
            "catbox": CatboxService(),
            "litterbox": LitterboxService(),
            "temp.sh": TempShService(),
            "gofile": GofileService(),
            "0x0": NullPointerService(),
            "pixeldrain": PixeldrainService(os.environ.get("PIXELDRAIN_API_KEY", "")),
            "termbin": TermbinService(),
            "drop.plz.ac": DropPlzAcService(),
            "sharenation": ShareNationService(),
            "x0.at": X0AtService(),
            "uguu": UguuService(),
            "tmpfiles": TmpfilesService(),
            "filebin": FilebinService(),
        }

    def load_perf(self):
        if self.perf_file.exists():
            try:
                data = json.loads(self.perf_file.read_text())
                for svc, rec in data.items():
                    self.perf[svc] = PerfRecord(
                        upload_times=rec.get("upload_times", []),
                        success_count=rec.get("success_count", 0),
                        failure_count=rec.get("failure_count", 0),
                        avg_speed_mbps=rec.get("avg_speed_mbps", 0.0)
                    )
            except:
                pass

    def save_perf(self):
        data = {}
        for svc, rec in self.perf.items():
            data[svc] = {
                "upload_times": rec.upload_times[-10:],
                "success_count": rec.success_count,
                "failure_count": rec.failure_count,
                "avg_speed_mbps": rec.avg_speed_mbps,
            }
        self.perf_file.write_text(json.dumps(data, indent=2))

    def record_upload(self, svc: str, elapsed: float, success: bool, size_mb: float):
        if svc not in self.perf:
            self.perf[svc] = PerfRecord()
        rec = self.perf[svc]
        rec.upload_times.append(elapsed)
        rec.upload_times = rec.upload_times[-10:]
        if success:
            rec.success_count += 1
            if elapsed > 0:
                speed = size_mb / elapsed
                rec.avg_speed_mbps = 0.7 * rec.avg_speed_mbps + 0.3 * speed if rec.avg_speed_mbps else speed
        else:
            rec.failure_count += 1
        self.save_perf()

    def smart_select(self, file_path: str, preferred: Optional[List[str]] = None) -> str:
        size_mb = os.path.getsize(file_path) / (1024 * 1024)
        candidates = preferred or UPLOAD_SERVICES

        eligible = []
        for svc in candidates:
            s = self.services.get(svc)
            if not s:
                continue
            if s.max_size_mb > 0 and size_mb > s.max_size_mb:
                continue
            if s.needs_key and not os.environ.get("PIXELDRAIN_API_KEY"):
                continue
            eligible.append(svc)

        if not eligible:
            raise RuntimeError(f"No service can handle {size_mb:.1f}MB file")

        def score(svc_name: str) -> float:
            rec = self.perf.get(svc_name, PerfRecord())
            speed = rec.avg_speed_mbps if rec.avg_speed_mbps else 1.0
            total = rec.success_count + rec.failure_count
            rate = rec.success_count / total if total > 0 else 0.5
            penalty = rec.failure_count * 0.3
            return speed * 3 + rate * 2 - penalty

        eligible.sort(key=score, reverse=True)
        return eligible[0]

    def upload(self, file_path: str, service: str = None, **kwargs) -> UploadResult:
        path = Path(file_path)
        if not path.exists():
            raise FileNotFoundError(file_path)

        if service:
            if service not in self.services:
                raise ValueError(f"Unknown service: {service}")
            svc_name = service
        else:
            svc_name = self.smart_select(file_path)

        svc = self.services[svc_name]
        print(f"[*] Uploading to {svc_name}...", file=sys.stderr)
        size_mb = os.path.getsize(file_path) / (1024 * 1024)

        t0 = time.time()
        success = False
        try:
            result = svc.upload(file_path, **kwargs)
            success = True
            elapsed = time.time() - t0
            self.record_upload(svc_name, elapsed, True, size_mb)
            return result
        except Exception as e:
            elapsed = time.time() - t0
            self.record_upload(svc_name, elapsed, False, size_mb)
            print(f"[!] {svc_name} failed: {e}", file=sys.stderr)
            fallback = [s for s in UPLOAD_SERVICES if s != svc_name and not self.services[s].needs_key]
            for fb in fallback[:3]:
                print(f"[*] Trying fallback: {fb}...", file=sys.stderr)
                try:
                    return self.upload(file_path, service=fb, **kwargs)
                except Exception as e2:
                    print(f"[!] {fb} also failed: {e2}", file=sys.stderr)
            raise RuntimeError(f"All services failed. Last error: {e}")

    def download(self, url: str, output_path: str = None) -> bool:
        parsed = urlparse(url)
        domain = parsed.netloc.lower()

        svc_name = None
        for name in self.services:
            key = name.replace(".", "")
            if key in domain or name in domain:
                svc_name = name
                break

        if not svc_name:
            # Try generic direct download
            out = output_path or str(Path(os.getcwd()) / "downloaded_file")
            code, _, _ = self.services["catbox"]._curl(["-o", str(out), url])
            return code == 0 and os.path.exists(out) and os.path.getsize(out) > 0

        svc = self.services[svc_name]
        if not output_path:
            out = Path(os.getcwd()) / Path(url).name
            if not out.name or out.name in ["", "/"]:
                out = Path(os.getcwd()) / "downloaded_file"
            output_path = str(out)

        print(f"[*] Downloading from {svc_name}...", file=sys.stderr)
        return svc.download(url, output_path)

    def update(self):
        """Self-update via git pull from GitHub raw URLs."""
        raw_base = "https://raw.githubusercontent.com/evangit2/tmp-cli/master"
        script_dir = self.config_dir.parent / "tmp-cli" if hasattr(self.config_dir, "parent") else Path.home() / ".tmp-cli"
        # Common install locations
        for cand in [Path.home() / ".tmp-cli", Path.home() / ".config" / "tmp-cli", Path.home() / ".local" / "share" / "tmp-cli"]:
            if (cand / "tmpcli").exists() or (cand / "tmp").exists():
                script_dir = cand
                break

        print(f"[*] tmpcli update — checking {raw_base} ...", file=sys.stderr)
        # Download latest tmpcli
        _, out, err = self.services["catbox"]._curl([
            "-o", str(script_dir / "tmpcli.new"),
            f"{raw_base}/tmpcli"
        ])
        if _ != 0:
            raise RuntimeError(f"Failed to fetch latest tmpcli: {err}")
        # Download latest install.sh for metadata
        _, out2, _ = self.services["catbox"]._curl([
            "-o", str(script_dir / "install.sh.new"),
            f"{raw_base}/install.sh"
        ])
        # Verify new script is valid Python
        new_path = script_dir / "tmpcli.new"
        content = new_path.read_text()
        if "#!/usr/bin/env python3" not in content or "def main():" not in content:
            new_path.unlink(missing_ok=True)
            raise RuntimeError("Downloaded file does not look like tmpcli — update aborted")
        # Backup and swap
        old_path = script_dir / "tmpcli"
        old_path.replace(script_dir / "tmpcli.bak")
        new_path.rename(old_path)
        old_path.chmod(0o755)
        (script_dir / "install.sh.new").rename(script_dir / "install.sh")
        print("[+] tmpcli updated successfully.", file=sys.stderr)
        print("    Backup: tmpcli.bak", file=sys.stderr)
        return True


# ─── Argparse ──────────────────────────────────────────────────────────────

SERVICE_CHOICES = list(TmpCli().services.keys())

def main():
    parser = argparse.ArgumentParser(prog="tmpcli", description="Universal temp file uploader/downloader")
    subparsers = parser.add_subparsers(dest="command", help="Commands")

    # upload
    up = subparsers.add_parser("up", help="Upload file")
    up.add_argument("file", help="File to upload")
    up.add_argument("-s", "--service", choices=SERVICE_CHOICES, help="Target service")
    up.add_argument("-t", "--time", default="72h", help="Expire time (litterbox: 1h/12h/24h/72h)")
    up.add_argument("-n", "--name", help="Custom filename on server")
    up.add_argument("--secret", action="store_true", help="Use secret URL (0x0.st)")
    up.add_argument("--expires", type=int, default=3600, help="Seconds until expiry (sharenation/tmpfiles)")
    up.add_argument("--filebin-bin", help="Bin ID for filebin.net uploads")
    up.add_argument("--pixeldrain-key", help="Pixeldrain API key")
    up.add_argument("-q", "--quiet", action="store_true", help="Only print URL to stdout")

    # download
    dl = subparsers.add_parser("dl", help="Download file")
    dl.add_argument("url", help="URL to download")
    dl.add_argument("-o", "--output", help="Output path")

    # list / catalog
    ls = subparsers.add_parser("list", help="List services and status")
    ls.add_argument("--perf", action="store_true", help="Show performance stats")
    cat = subparsers.add_parser("catalog", help="Show service catalog with verified limits")
    cat.add_argument("--json", action="store_true", help="JSON output for scripts")

    # update
    upd = subparsers.add_parser("update", help="Update tmpcli from GitHub")

    args = parser.parse_args()
    cli = TmpCli()

    if args.command in ("up",):
        kwargs = {}
        if args.service == "litterbox":
            kwargs["time_param"] = args.time
        if args.service == "0x0" and args.secret:
            kwargs["secret"] = True
        if args.expires:
            kwargs["expires_seconds"] = args.expires
            kwargs["tmpfiles_expire"] = args.expires
        if args.filebin_bin:
            kwargs["filebin_bin"] = args.filebin_bin
        if args.name:
            kwargs["filename"] = args.name
        if args.pixeldrain_key:
            os.environ["PIXELDRAIN_API_KEY"] = args.pixeldrain_key
        result = cli.upload(args.file, service=args.service, **kwargs)
        if args.quiet:
            print(result.url)
        else:
            print(f"[+] Uploaded: {result.url}  ({result.service}, {result.expires_in})", file=sys.stderr)
            print(result.url)

    elif args.command in ("dl",):
        ok = cli.download(args.url, args.output)
        sys.exit(0 if ok else 1)

    elif args.command == "list":
        print(f"{'Service':<16} {'Upload':<7} {'Download':<9} {'Max':<8} {'Expiry':<14} Notes")
        print("-" * 70)
        for name, info in CATALOG.items():
            if name.startswith("_"):
                continue
            mb = f"{info['max_mb']}MB" if info['max_mb'] else 'unltd'
            print(f"{name:<16} {info['upload']:<7} {info['download']:<9} {mb:<8} {info['expiry']:<14} {info['notes']}")
        if args.perf:
            print("\nPerformance:")
            for name, rec in cli.perf.items():
                print(f"  {name}: avg={rec.avg_speed_mbps:.2f}MB/s  succ={rec.success_count}  fail={rec.failure_count}")

    elif args.command == "catalog":
        if args.json:
            clean = {k: v for k, v in CATALOG.items() if not k.startswith("_")}
            print(json.dumps(clean, indent=2))
        else:
            W = 70
            print(f"{'Service':^16} │ {'Upload':^6} │ {'Download':^8} │ {'Max':^8} │ {'Expiry':^12}")
            print("─" * W)
            for name, info in CATALOG.items():
                if name.startswith("_"):
                    continue
                mb = f"{info['max_mb']}MB" if info['max_mb'] else "unlimited"
                print(f"{name:<16} │ {info['upload']:^6} │ {info['download']:^8} │ {mb:^8} │ {info['expiry']:<12}")
            if "_skipped" in CATALOG:
                print("\nSkipped (require client-side crypto or captcha):")
                for svc, reason in CATALOG["_skipped"].items():
                    print(f"  {svc}: {reason['reason']}")

    elif args.command == "update":
        try:
            cli.update()
        except Exception as e:
            print(f"[!] Update failed: {e}", file=sys.stderr)
            sys.exit(1)
    else:
        parser.print_help()

if __name__ == "__main__":
    main()
